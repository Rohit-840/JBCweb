NODE_ENV=production
PORT=3000

# MongoDB connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE

# Use a long random secret and never change it after MT5 passwords are stored,
# because the same secret currently protects JWTs and encrypts saved MT5 passwords.
JWT_SECRET=replace-with-a-long-random-secret

# Internal FastAPI MT5 bridge URL.
PYTHON_SERVICE_URL=http://127.0.0.1:8001

# Comma-separated origins allowed to call the API.
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# Keep false in production unless you intentionally test across a LAN.
ALLOW_PRIVATE_NETWORK_CORS=false
